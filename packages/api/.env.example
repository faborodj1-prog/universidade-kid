# ─── BANCO DE DADOS ──────────────────────────────────────────────────────────
# Use Neon.tech (grátis, sem expiração): https://neon.tech
# Render removeu PostgreSQL gratuito — NÃO use o banco do Render no free tier
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── AUTENTICAÇÃO ────────────────────────────────────────────────────────────
JWT_SECRET="troque-por-string-aleatoria-de-64-chars"
JWT_REFRESH_SECRET="outro-secret-diferente-do-acima"

# ─── CLOUDINARY (upload de fotos) ────────────────────────────────────────────
# Conta grátis em https://cloudinary.com — 25 GB inclusos
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── SERVIDOR ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Caminho para o build do frontend (relativo à raiz do monorepo)
STATIC_PATH=packages/web/dist
