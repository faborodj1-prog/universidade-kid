# ─── BANCO DE DADOS ──────────────────────────────────────────────────────────
# Use Neon.tech (grátis, sem cartão): https://neon.tech
# Crie um projeto → copie a connection string (formato abaixo)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── AUTENTICAÇÃO ────────────────────────────────────────────────────────────
JWT_SECRET="troque-por-string-aleatoria-de-64-chars"
JWT_REFRESH_SECRET="outro-secret-diferente-do-acima"

# ─── CLOUDINARY (upload de fotos) ────────────────────────────────────────────
# Conta grátis em https://cloudinary.com — 25 GB inclusos, sem cartão
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── CORS ────────────────────────────────────────────────────────────────────
# URL do frontend no Vercel (preencher após o deploy do web)
# Ex: ALLOWED_ORIGIN=https://universidade-kid.vercel.app
ALLOWED_ORIGIN=""

# ─── SERVIDOR (desenvolvimento local) ────────────────────────────────────────
PORT=3001
NODE_ENV=development
